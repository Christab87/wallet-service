<!-- 
PLACEHOLDER: Maskable icon (192x192) - for adaptive icons on Android

Maskable icons should have the important content within the center "safe zone" (radius 40).
-->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192">
  <!-- Safe zone circle (visible area after masking) -->
  <circle cx="96" cy="96" r="60" fill="#1e3a5f"/>
  <circle cx="96" cy="96" r="55" fill="#0f2942"/>
  
  <!-- BTC symbol centered in safe zone -->
  <text x="96" y="110" font-size="60" font-weight="bold" text-anchor="middle" fill="#22c55e" font-family="Arial">₿</text>
</svg>
