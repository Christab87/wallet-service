<!-- 
PLACEHOLDER: Maskable icon (512x512) - for adaptive icons on Android

Maskable icons should have the important content within the center "safe zone" (radius ~160).
-->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <!-- Safe zone circle (visible area after masking) -->
  <circle cx="256" cy="256" r="160" fill="#1e3a5f"/>
  <circle cx="256" cy="256" r="150" fill="#0f2942"/>
  
  <!-- BTC symbol centered in safe zone -->
  <text x="256" y="290" font-size="160" font-weight="bold" text-anchor="middle" fill="#22c55e" font-family="Arial">₿</text>
</svg>
